# ============================================================
# IPure Herbs — Production .env Template
# Copy to: /var/www/backend/.env
# ============================================================

APP_NAME="IPure Herbs"
APP_ENV=production
APP_KEY=                          # run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.ipureherbs.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ── Database ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                 # localhost on VPS (not mysql.railway.internal)
DB_PORT=3306
DB_DATABASE=ipureherbs
DB_USERNAME=ipure
DB_PASSWORD=Change_This_Strong_Password_123!

# ── Sessions & Cache ──────────────────────────────────────
SESSION_DRIVER=redis              # use redis for better performance
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=database         # or redis if you prefer

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (Mailgun recommended) ────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@mg.ipureherbs.com
MAIL_PASSWORD=your_mailgun_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ipureherbs.com
MAIL_FROM_NAME="IPure Herbs"

# ── Stripe ────────────────────────────────────────────────
STRIPE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.ipureherbs.com/api/auth/google/callback

# ── File Storage ──────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Logging ───────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error                   # only log errors in production

# ── Frontend URL (for CORS) ───────────────────────────────
FRONTEND_URL=https://ipureherbs.com
